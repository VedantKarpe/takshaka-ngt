{
  "name": "takshaka-ngt",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "smoke": "node smoke-test.mjs",
    "models:export": "blender --background --python blender_scripts/export_models.py",
    "models:optimize": "for f in src/assets/models/*.glb; do npx @gltf-transform/cli optimize \"$f\" \"$f\" --texture-compress ktx2 --compress draco; done",
    "build:pages": "ng build --configuration production --base-href /takshaka-ngt/ && cp dist/takshaka-ngt/browser/index.html dist/takshaka-ngt/browser/404.html"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@pmndrs/vanilla": "^1.25.0",
    "angular-three": "^3.7.2",
    "angular-three-postprocessing": "^3.7.2",
    "angular-three-soba": "^3.7.2",
    "camera-controls": "^3.1.2",
    "maath": "^0.10.8",
    "meshline": "^3.3.1",
    "ngxtension": "^7.2.0",
    "postprocessing": "^6.39.1",
    "rxjs": "~7.8.0",
    "three": "^0.171.0",
    "three-mesh-bvh": "^0.9.10",
    "three-stdlib": "^2.36.1",
    "troika-three-text": "^0.52.4",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.2",
    "@angular/cli": "^19.0.2",
    "@angular/compiler-cli": "^19.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/three": "^0.171.0",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "puppeteer-core": "^23.11.1",
    "typescript": "~5.6.2"
  }
}
